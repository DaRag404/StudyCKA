#!/bin/sh
REPO_ROOT=$(git rev-parse --show-toplevel)
EXIT_CODE=0

# Auto-fix what ESLint can fix automatically
for dir in backend frontend; do
  echo "→ ESLint --fix $dir"
  cd "$REPO_ROOT/$dir"
  npx eslint --fix src 2>/dev/null || true
done

# If auto-fix modified source files, stop and ask user to commit the fixes
cd "$REPO_ROOT"
FIXED=$(git diff --name-only backend/src frontend/src)
if [ -n "$FIXED" ]; then
  echo ""
  echo "ESLint applied automatic fixes to:"
  echo "$FIXED"
  echo ""
  echo "Please review, stage, and commit these changes before pushing."
  exit 1
fi

# Final lint check — fail push if unfixable errors remain
for dir in backend frontend; do
  echo "→ ESLint $dir"
  cd "$REPO_ROOT/$dir"
  if ! npx eslint src; then
    EXIT_CODE=1
  fi
done

exit $EXIT_CODE
